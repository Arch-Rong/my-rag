# 火山方舟 Ark（豆包）— https://console.volcengine.com/ark
ARK_API_KEY=your-ark-api-key
ARK_API_BASE=https://ark.cn-beijing.volces.com/api/v3

# 控制台「推理接入点」里的 Endpoint ID / 模型名（必填，不能留空）
AGENT_MODEL=doubao-seed-1-6-flash-250715

# 文本向量化（与 EMBEDDING_DIM 一致，火山控制台 Embedding 模型）
EMBEDDING_MODEL=doubao-embedding-large-text-240915
EMBED_ON_INGEST=true

# 可选
# AGENT_SYSTEM_PROMPT=你是 MedRAG 医学生学习助手

# 兼容旧变量名（可不填，优先用 ARK_API_KEY）
# OPENAI_API_KEY=
# OPENAI_API_BASE=

# PostgreSQL + pgvector（先 docker compose up，再 alembic upgrade head）
DATABASE_URL=postgresql+psycopg://medrag:medrag@127.0.0.1:5432/medrag
EMBEDDING_DIM=1024
# DATABASE_ECHO=true

# MinIO 对象存储（docker compose 启动后可用）
STORAGE_BACKEND=s3
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=medrag
S3_SECRET_KEY=medrag_dev
S3_BUCKET=medrag-uploads
S3_REGION=us-east-1
# 本地上传目录（仅 STORAGE_BACKEND=filesystem 时）
# STORAGE_LOCAL_ROOT=./data/object-storage
# MAX_UPLOAD_BYTES=52428800

# JWT（生产务必更换）
JWT_SECRET_KEY=dev-change-me-use-openssl-rand-hex-32
JWT_EXPIRE_MINUTES=10080

# 结构分片
CHUNK_MAX_TOKENS=512
CHUNK_OVERLAP_TOKENS=64
